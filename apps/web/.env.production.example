# Safe defaults for `npm run build` (no secrets). Copied to .env.production when that file is missing.
# Override locally in apps/web/.env.production (gitignored) if you use a different PocketBase URL.
VITE_POCKETBASE_URL=/hcgi/platform
# Used when generating sitemap.xml / rss.xml in dist (same origin as public site).
SITE_URL=https://flowseekerlab.io
