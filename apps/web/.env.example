# After `git clone`: from repo root run `npm run bootstrap` (creates .env and .env.production from *.example).
# Local dev (npm run dev) — or copy this file to .env manually
# PocketBase API (dev: full URL; production on Hostinger: same-origin proxy path, e.g. /hcgi/platform)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# Production build (`npm run build` / Hostinger deploy) reads apps/web/.env.production only.
# Keep VITE_POCKETBASE_URL identical to what the live site must call (one backend = same behaviour everywhere).
# Build-time sitemap/RSS (`tools/generate-public-feeds.mjs`) uses SITE_URL if set (default https://flowseekerlab.io).
# SITE_URL=https://flowseekerlab.io
# Optional analytics (public site only):
# VITE_PLAUSIBLE_DOMAIN=flowseekerlab.io
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional footer links (full https URLs). Omit to hide placeholder social / legal links.
# VITE_SITE_TWITTER_URL=https://x.com/yourhandle
# VITE_SITE_LINKEDIN_URL=https://www.linkedin.com/in/yourprofile
# VITE_SITE_GITHUB_URL=https://github.com/yourorg
# VITE_SITE_PRIVACY_URL=https://flowseekerlab.io/privacy
# VITE_SITE_TERMS_URL=https://flowseekerlab.io/terms
